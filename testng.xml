<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml — TestNG suite configuration for automationexercise.com

    HOW TO RUN:
      All tests  : mvn test
      Smoke only : mvn test -Dgroups="smoke"
      Regression : mvn test -Dgroups="regression"

    KEY ATTRIBUTES:
      verbose      — console log level: 0=silent, 2=normal, 10=very detailed
      parallel     — "methods"|"classes"|"tests"|"none"
      thread-count — number of threads (only applies when parallel is set)
-->
<suite name="AutomationExercise Test Suite" verbose="2">

    <!-- =====================================================================
         SMOKE SUITE — quick sanity check, runs only @Test(groups="smoke")
    ====================================================================== -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.ProductsTest"/>
            <class name="com.automation.tests.CartTest"/>
        </classes>
    </test>

    <!-- =====================================================================
         REGRESSION SUITE — full suite, runs all @Test methods
    ====================================================================== -->
    <test name="Regression Tests">
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.ProductsTest"/>
            <class name="com.automation.tests.CartTest"/>
        </classes>
    </test>

</suite>
